{
  "name": "freeweb-mcp",
  "version": "3.0.2",
  "description": "Secure MCP server for web browsing with multi-layer fetcher chain - no API keys required",
  "keywords": [
    "mcp",
    "playwright",
    "github",
    "web-browsing",
    "ai-tools",
    "model-context-protocol",
    "web-scraping",
    "search",
    "rss",
    "llms-txt",
    "fetcher-chain"
  ],
  "author": "xenit",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "freeweb-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^17.4.1",
    "jsdom": "^29.0.2",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.13.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xenitV1/freeweb.git"
  },
  "bugs": {
    "url": "https://github.com/xenitV1/freeweb/issues"
  },
  "homepage": "https://github.com/xenitV1/freeweb#readme"
}
